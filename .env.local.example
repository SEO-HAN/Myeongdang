# ─────────────────────────────────────────────
# 명당지도 환경 변수 설정 가이드
# 이 파일을 복사해서 .env.local 로 저장 후 실제 값으로 채우세요.
# .env.local 은 절대 git에 커밋하지 마세요!
# ─────────────────────────────────────────────

# ── 카카오 ──────────────────────────────────
# https://developers.kakao.com 에서 앱 생성 후 발급
# 플랫폼 > Web > 사이트 도메인: http://localhost:3000 추가 필수
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# 카카오 로그인 (OAuth)
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here

# ── Supabase ─────────────────────────────────
# https://supabase.com/dashboard → 프로젝트 Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 서버 전용 (서버 컴포넌트, Route Handler에서만 사용)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── 앱 설정 ─────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=명당지도

# ── Claude API (데이터 파이프라인용, 선택) ──
ANTHROPIC_API_KEY=your-anthropic-api-key-here
